#!/usr/bin/env bash
set -euo pipefail

CONFIG_DIR="${MIHOMO_CONFIG_DIR:-/etc/mihomo}"
PID_FILE="${MIHOMO_PID_FILE:-/tmp/mihomo.pid}"
LOG_FILE="${MIHOMO_LOG_FILE:-/tmp/mihomo.log}"
MIHOMO_BIN="${MIHOMO_BIN:-mihomo}"

is_running() {
  if [ -f "$PID_FILE" ]; then
    local pid
    pid="$(cat "$PID_FILE" 2>/dev/null || true)"
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
  fi
  pgrep -f "$MIHOMO_BIN -d $CONFIG_DIR" >/dev/null 2>&1
}

get_pid() {
  if [ -f "$PID_FILE" ]; then
    local pid
    pid="$(cat "$PID_FILE" 2>/dev/null || true)"
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      echo "$pid"
      return 0
    fi
  fi
  pgrep -f "$MIHOMO_BIN -d $CONFIG_DIR" | head -n 1 || true
}

usage() {
  cat <<'USAGE'
用法：
  mihomo-bg run       前台运行 mihomo，适合调试
  mihomo-bg start     后台启动 mihomo
  mihomo-bg stop      停止 mihomo
  mihomo-bg restart   重启 mihomo
  mihomo-bg status    查看状态
  mihomo-bg log       查看日志

环境变量：
  MIHOMO_CONFIG_DIR=/etc/mihomo
  MIHOMO_PID_FILE=/tmp/mihomo.pid
  MIHOMO_LOG_FILE=/tmp/mihomo.log
  MIHOMO_BIN=mihomo
USAGE
}

cmd="${1:-status}"

case "$cmd" in
  run)
    exec sudo "$MIHOMO_BIN" -d "$CONFIG_DIR"
    ;;

  start)
    if is_running; then
      echo "mihomo 已在运行，PID: $(get_pid)"
      exit 0
    fi
    : > "$LOG_FILE"
    echo "启动 mihomo: $MIHOMO_BIN -d $CONFIG_DIR"
    # 用 bash -c 获取 sudo 后台进程 PID。
    sudo bash -c "nohup '$MIHOMO_BIN' -d '$CONFIG_DIR' >> '$LOG_FILE' 2>&1 & echo \$! > '$PID_FILE'"
    sleep 1
    if is_running; then
      echo "启动成功，PID: $(get_pid)"
      echo "日志: $LOG_FILE"
    else
      echo "启动失败，最近日志：" >&2
      tail -n 80 "$LOG_FILE" >&2 || true
      exit 1
    fi
    ;;

  stop)
    pid="$(get_pid)"
    if [ -z "$pid" ]; then
      echo "mihomo 未运行"
      rm -f "$PID_FILE"
      exit 0
    fi
    echo "停止 mihomo，PID: $pid"
    sudo kill "$pid" 2>/dev/null || true
    sleep 1
    if kill -0 "$pid" 2>/dev/null; then
      echo "普通停止失败，尝试 kill -9"
      sudo kill -9 "$pid" 2>/dev/null || true
    fi
    rm -f "$PID_FILE"
    echo "已停止"
    ;;

  restart)
    "$0" stop || true
    "$0" start
    ;;

  status)
    if is_running; then
      echo "mihomo 正在运行，PID: $(get_pid)"
      echo "配置目录: $CONFIG_DIR"
      echo "日志: $LOG_FILE"
    else
      echo "mihomo 未运行"
      echo "配置目录: $CONFIG_DIR"
    fi
    ;;

  log)
    if [ ! -f "$LOG_FILE" ]; then
      echo "日志文件不存在: $LOG_FILE"
      exit 1
    fi
    tail -f "$LOG_FILE"
    ;;

  help|-h|--help)
    usage
    ;;

  *)
    echo "未知命令: $cmd" >&2
    usage
    exit 1
    ;;
esac
